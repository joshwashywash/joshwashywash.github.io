---
import Base from '../layouts/Base.astro';
import IconLink from '../components/IconLink.svelte';
import type { Link } from '../types';

const links: Link[] = [
	{
		href: 'https://github.com/joshwashywash',
		to: 'github',
	},
	{
		href: 'https://twitter.com/joshwashywash',
		to: 'twitter',
	},
];
---

<Base>
	<main
		class="flex min-h-screen max-w-sm grow flex-col items-center justify-center gap-4 sm:max-w-none"
	>
		<h1 class="text-center text-7xl sm:text-8xl">josh oertel</h1>
		<div class="flex flex-col gap-2 sm:flex-row">
			{links.map((link) => <IconLink {link} client:load />)}
		</div>
	</main>
</Base>
