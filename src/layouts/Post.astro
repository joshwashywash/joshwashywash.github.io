---
import Base from '../layouts/Base.astro';

export interface Props {
	content: {
		date: string;
		description: string;
		title: string;
	};
}

const {
	content: { date, description, title },
} = Astro.props;
---

<Base title={title} description={description}>
	<article class="container prose prose-rose mb-32 px-4 pt-4 lg:prose-xl">
		<h1>{title}</h1>
		{
			date && (
				<time>
					{new Date(date).toLocaleDateString('en-us', {
						timeZone: 'UTC',
					})}
				</time>
			)
		}
		<slot />
	</article>
</Base>
